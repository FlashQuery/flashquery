# ============================================================================
# FlashQuery — Environment Variables
# ============================================================================
# The easiest way to populate this file is to run `./setup.sh` from the repo
# root. It will prompt you for the essentials, generate any secrets that
# need generating (like MCP_AUTH_SECRET), and produce a ready-to-use .env.
# You can always edit it by hand afterwards; the prompts are just a
# shortcut.
#
# Copy this file to .env and fill in your values. .env is gitignored and
# should never contain real secrets in a committed form.
#
# This file configures the FlashQuery application itself. If you are
# running the bundled Supabase stack under docker/, there is a separate
# .env.docker file in that directory for the Docker services — see
# docker/.env.docker.example. The two files are intentionally distinct:
# each stands on its own, and values that appear in both (SUPABASE_URL,
# SUPABASE_SERVICE_ROLE_KEY, VAULT_PATH) should be kept in sync by hand
# or by re-running setup.sh.
#
# Required variables (FlashQuery will not start without these):
#   SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY, DATABASE_URL, VAULT_PATH
#   INSTANCE_NAME, INSTANCE_ID
#   MCP_AUTH_SECRET (generated by setup.sh)
# Required for semantic search and LLM features:
#   OPENAI_API_KEY (or equivalent key for your chosen llm: provider)
# ============================================================================


# === Supabase Connection (required) =========================================

SUPABASE_URL=https://your-project.supabase.co
# Base URL for your Supabase instance.
#   Supabase Cloud:        https://<your-project>.supabase.co
#                          (Dashboard → Settings → API → Project URL)
#   Self-hosted (bundled): http://localhost:8000
#                          (Kong API gateway port, NOT the direct Postgres port)
#   Self-hosted (other):   http://<host>:8000
# Also referenced by docker/.env.docker when using the bundled stack — keep
# the two in sync if you edit manually.

SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Service-role key for privileged operations (schema creation, RLS bypass).
#   Supabase Cloud:        Dashboard → Settings → API → service_role secret
#   Self-hosted (bundled): printed by Supabase on first startup; for a
#                          quick-start dev setup the bundled docker-compose
#                          can use a shared JWT secret (see .env.docker.example)
# Also referenced by docker/.env.docker when using the bundled stack.

DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres
# Direct Postgres connection string (used for DDL, vector ops, and anything
# that bypasses PostgREST). Format: postgresql://[user]:[password]@[host]:[port]/[db]
#   Supabase Cloud:        Dashboard → Settings → Database → Connection string
#                          (pick "Session" or "Transaction" mode intentionally)
#   Self-hosted (bundled): postgresql://postgres:<POSTGRES_PASSWORD>@localhost:5432/flashquery
#                          The bundled Docker stack exposes Postgres on 5432.
#                          NOTE: port 5432 is the direct Postgres port. Port
#                          8000 is Kong, not Postgres — do not mix them up.


# === Instance Identity (required) ===========================================

INSTANCE_NAME=My FlashQuery
# Human-readable label for this FlashQuery installation.
# Examples: "My Knowledge Base", "Work Vault", "Personal Notes"

INSTANCE_ID=my-fqc
# Unique identifier for this instance — used in every database row FlashQuery writes,
# so every instance sharing a Supabase DB needs a distinct ID.
# Convention: use an "i-" prefix for readability (e.g., i-abc123).


# === Vault (required) =======================================================

VAULT_PATH=./vault
# Local directory for your markdown vault (Obsidian-compatible).
# Absolute paths recommended for clarity in production; relative paths are
# resolved from wherever you launch FlashQuery.
# Also referenced by docker/.env.docker for the container volume mount when
# using the bundled stack — keep the two in sync if you edit manually.


# === LLM Providers (required for semantic search and language features) ======
# Keys for providers configured in the llm: section of flashquery.yml.
# OPENAI_API_KEY covers both language models and embedding models when using
# OpenAI as the provider.

OPENAI_API_KEY=sk-proj-...
# API key for OpenAI. Required when any model in llm.providers uses OpenAI.
#   https://platform.openai.com/api-keys

# OPENROUTER_API_KEY=
# GROQ_API_KEY=

# OLLAMA_URL=http://localhost:11434
# Base URL for a local Ollama instance. Only needed when using Ollama as an
# llm: provider. Change if Ollama runs on a different host or port.


# === MCP Transport (required) ===============================================

MCP_AUTH_SECRET=
# HMAC-SHA256 signing key used by FlashQuery to issue bearer tokens on the /token
# endpoint when mcp.transport is "streamable-http" (the default in
# flashquery.yml). setup.sh generates this automatically — 32 hex bytes is
# sufficient.
# Generate manually with: openssl rand -hex 32
# See docs/SECURITY-TOKENS.md for how tokens are consumed by MCP clients.


# === Logging (optional) =====================================================

LOG_LEVEL=info
# Verbosity. Supported: debug, info, warn, error.


# === Runtime (optional) =====================================================

NODE_ENV=development
# Node.js runtime mode. Supported: development, production, test.
# Affects Node's internal optimizations and some third-party libraries'
# behavior. Not read by FlashQuery directly.
