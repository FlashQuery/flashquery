{
  "name": "flashquery",
  "version": "5.1.0",
  "description": "Open source, local-first data management layer for AI workflows",
  "type": "module",
  "bin": {
    "flashquery": "./dist/index.js"
  },
  "files": [
    "dist/",
    "LICENSE",
    "README.md",
    "NOTICE",
    "docs/ARCHITECTURE.md",
    "docs/client-configs/",
    "setup/",
    ".env.example",
    "flashquery.example.yml",
    "docker/.env.docker.example"
  ],
  "scripts": {
    "setup": "bash setup/setup.sh",
    "dev": "tsx src/index.ts start --config ./flashquery.yml",
    "dev:test": "DOTENV_CONFIG_PATH=./.env.test tsx src/index.ts start --config ./flashquery.yml",
    "build": "tsup src/index.ts --format esm --dts",
    "start": "node dist/index.js start --config ./flashquery.yml",
    "test": "npm run test:unit && npm run test:macro-framework",
    "test:unit": "vitest run --config tests/config/vitest.unit.config.ts",
    "test:watch": "vitest --config tests/config/vitest.unit.config.ts",
    "test:integration": "vitest run --config tests/config/vitest.integration.config.ts",
    "test:macro-framework": "vitest run --config tests/config/vitest.macro-framework.config.ts",
    "coverage:macro-framework": "tsx tests/macro-framework/coverage/render.ts",
    "run:macro-framework": "tsx tests/macro-framework/triage/run-cli.ts",
    "test:e2e": "vitest run --config tests/config/vitest.e2e.config.ts",
    "test:benchmark": "vitest run --config tests/config/vitest.benchmark.config.ts",
    "typecheck": "tsc --noEmit",
    "knip": "knip --no-config-hints",
    "lint": "eslint src/ --max-warnings 0",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "test:docker-smoke": "bash scripts/smoke-test.sh",
    "preflight": "npm run lint && npm run typecheck && npm run knip && npm run preflight:test && npm run preflight:pack && npm run preflight:docker",
    "preflight:test": "vitest run --config tests/config/vitest.preflight.config.ts",
    "preflight:pack": "node -e \"const{execSync}=require('child_process');const allowedEnv=new Set(['.env.example','docker/.env.docker.example']);const p=JSON.parse(execSync('npm pack --dry-run --json').toString())[0];const bad=p.files.filter(f=>f.path.includes('src/')||f.path.includes('tests/')||(f.path.includes('.env')&&!allowedEnv.has(f.path))||f.path.includes('node_modules/'));if(bad.length){console.error('Unwanted files in package:',bad.map(f=>f.path));process.exit(1);}console.log('Package contents OK');\"",
    "preflight:docker": "bash scripts/preflight-docker.sh"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@supabase/supabase-js": "^2.106.2",
    "async-mutex": "^0.5.0",
    "chevrotain": "^12.0.0",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1",
    "jsonrepair": "^3.14.0",
    "mdast-util-from-markdown": "^2.0.3",
    "mdast-util-gfm": "^3.1.0",
    "micromark-extension-gfm": "^3.0.0",
    "pg": "^8.21.0",
    "shelljs": "^0.10.0",
    "simple-git": "^3.33.0",
    "uuid": "^13.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/shelljs": "^0.10.0",
    "esbuild": "^0.27.7",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "knip": "^6.14.2",
    "markdown-table": "^3.0.4",
    "prettier": "^3.8.1",
    "tablemark": "^4.1.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.1"
  }
}
