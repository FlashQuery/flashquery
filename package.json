{
  "name": "flashquery",
  "version": "0.1.0",
  "description": "Open source, local-first data management layer for AI workflows",
  "type": "module",
  "bin": {
    "flashquery": "./dist/index.js"
  },
  "files": [
    "dist/",
    "LICENSE",
    "README.md",
    "NOTICE",
    "docs/ARCHITECTURE.md",
    "docs/client-configs/"
  ],
  "scripts": {
    "setup": "bash setup/setup.sh",
    "dev": "tsx src/index.ts start --config ./flashquery.yml",
    "dev:test": "DOTENV_CONFIG_PATH=./.env.test tsx src/index.ts start --config ./flashquery.yml",
    "build": "tsup src/index.ts --format esm --dts",
    "start": "node dist/index.js start --config ./flashquery.yml",
    "test": "vitest run --config tests/config/vitest.unit.config.ts",
    "test:watch": "vitest --config tests/config/vitest.unit.config.ts",
    "test:integration": "vitest run --config tests/config/vitest.integration.config.ts",
    "test:e2e": "vitest run --config tests/config/vitest.e2e.config.ts",
    "test:benchmark": "vitest run --config tests/config/vitest.benchmark.config.ts",
    "lint": "eslint src/ --max-warnings 0",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "preflight": "npm run lint && npm run preflight:test && npm run preflight:pack && npm run preflight:docker",
    "preflight:test": "vitest run --config tests/config/vitest.preflight.config.ts",
    "preflight:pack": "node -e \"const{execSync}=require('child_process');const p=JSON.parse(execSync('npm pack --dry-run --json').toString())[0];const bad=p.files.filter(f=>f.path.includes('src/')||f.path.includes('tests/')||f.path.includes('.env')||f.path.includes('node_modules/'));if(bad.length){console.error('Unwanted files in package:',bad.map(f=>f.path));process.exit(1);}console.log('Package contents OK');\"",
    "preflight:docker": "bash scripts/preflight-docker.sh"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "express": "^5.2.1",
    "@supabase/supabase-js": "^2.100.0",
    "async-mutex": "^0.5.0",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1",
    "pg": "^8.20.0",
    "simple-git": "^3.33.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.1"
  }
}
