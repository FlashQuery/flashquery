# ============================================================================
# FlashQuery — Docker Stack Environment Variables
# ============================================================================
# The easiest way to populate this file is to run `./setup.sh` from the repo
# root and choose the bundled Docker stack option. It will prompt you for
# shared values, generate any docker-only secrets (like POSTGRES_PASSWORD
# and SUPABASE_JWT_SECRET), and produce a ready-to-use .env.docker here.
# You can always edit it by hand afterwards; the prompts are just a
# shortcut.
#
# Copy this file to .env.docker and fill in your values. .env.docker is
# gitignored and should never contain real secrets in a committed form.
#
# This file configures ONLY the bundled Supabase Docker stack in this
# directory. The FlashQuery application itself is configured by the .env
# file at the repo root (see ../.env.example). The two files are
# intentionally distinct: each stands on its own, and values that appear
# in both (SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY, VAULT_PATH) should be
# kept in sync by hand or by re-running setup.sh.
#
# If you are using Supabase Cloud or an existing self-hosted Supabase
# instance, you do not need this file at all — only the root .env.
#
# How this file is consumed:
#   docker compose --env-file ./.env.docker -f docker-compose.yml up
# (Run from the docker/ directory. The --env-file flag is required because
# we use a non-default filename to keep this separate from the root .env.)
# ============================================================================


# === Docker stack secrets (required when using the bundled stack) ===========

POSTGRES_PASSWORD=
# Password for the bundled Postgres container. setup.sh generates this
# automatically (32 hex bytes). If you change it, you must also rebuild the
# Postgres volume — Postgres only reads POSTGRES_PASSWORD on initial data
# directory creation, not on every start.
# Generate manually with: openssl rand -hex 32

SUPABASE_JWT_SECRET=
# Shared HMAC secret used by PostgREST and GoTrue to sign and verify JWTs
# across the stack. Must be at least 32 characters. setup.sh generates this
# automatically. If you change it after starting the stack, you must also
# regenerate SUPABASE_ANON_KEY (it's a JWT signed with this secret).
# Generate manually with: openssl rand -hex 32

SUPABASE_ANON_KEY=
# Public anon-role JWT used by the bundled Supabase Studio container (the
# admin UI at http://localhost:3001 by default) to connect to the stack.
# This is a JWT signed with SUPABASE_JWT_SECRET above. FlashQuery itself
# does NOT use this key — it uses SUPABASE_SERVICE_ROLE_KEY for privileged
# access. The anon key is only needed so the Studio UI can log in.
# Leave blank on first setup; fill it in after running the stack once and
# retrieving it from the GoTrue container's startup logs or by generating
# it manually (see docs/SUPABASE-DOCKER.md if present).


# === Shared with root .env (duplicated so this file stands alone) ===========
# These values also appear in ../.env. Keep them in sync manually or by
# re-running setup.sh. If they ever drift, the root .env is canonical for
# the FlashQuery app and this file is canonical for the Docker stack —
# the first thing to check when FlashQuery and the stack disagree.

SUPABASE_URL=http://localhost:8000
# Base URL used by the FlashQuery container inside the Docker network to
# reach the Supabase stack's Kong API gateway. Compose substitutes this
# at container startup time. The stack's Kong listens on port 8000.
# Must match ../.env → SUPABASE_URL.

SUPABASE_SERVICE_ROLE_KEY=
# Service-role JWT used by the Studio admin UI and by the FlashQuery
# container. Signed with SUPABASE_JWT_SECRET; typically retrieved from
# the GoTrue container's startup logs on first run, or generated manually.
# Must match ../.env → SUPABASE_SERVICE_ROLE_KEY.

VAULT_PATH=./vault
# Host-side path to the vault directory. docker-compose mounts this into
# the FlashQuery container at /app/vault so both host and container see
# the same files.
# Must match ../.env → VAULT_PATH.


# === Docker-only paths (optional) ===========================================

LOG_PATH=./logs
# Host-side path for the FlashQuery log volume mount. Defaults to ./logs
# if unset, which is fine for most setups. FlashQuery itself logs to stdout
# by default, which Docker captures — set this only if you've configured
# logging.output: file in flashquery.yml and want the log files to persist
# on the host.
