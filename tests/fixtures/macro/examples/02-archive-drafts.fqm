# Archive every draft into a quarter folder.
# Uses mock FlashQuery tools — they print what they would have done.
#
# Demonstrates: namespaced tool calls (`fq.tool({...})`), assignment, for-loop,
# nested object literals for structured args, $obj.field access, count builtin,
# string interpolation.

fq.manage_directory({ action: "create", paths: ["Q3-2026"] })
drafts = fq.search({ query: "tag:#draft" })

for d in $drafts do
  fq.move_document({ identifier: $d.fq_id, destination_path: "Q3-2026/" })
  fq.apply_tags({ targets: [{ entity_type: "document", identifier: $d.fq_id }], tags: ["#archived"] })
done

total = count $drafts
echo "moved $total drafts to Q3-2026/"
