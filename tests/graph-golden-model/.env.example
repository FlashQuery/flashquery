# Copy to .env and edit. .env is gitignored.
#
# OpenAI-compatible base URL for the model server (local Ollama box).
GRAPH_GOLDEN_BASE_URL=http://192.168.15.12:11434/v1

# Active model. Override per run with --model (comma-separate for several at once).
GRAPH_GOLDEN_MODEL=gemma4:latest

# Model menu — all served at the URL above. Swap GRAPH_GOLDEN_MODEL or pass --model.
#   granite4        — first baseline tested; weak on the staleness_risk ordinal
#   gemma4:latest   — try this next
#   nemotron3:33b   — larger; use to probe the capability ceiling
# Example multi-model run:
#   npx tsx src/run.ts all --model "gemma4:latest,granite4,nemotron3:33b"

# Optional bearer token. Ollama ignores it; set it for hosted OpenAI-compat servers.
# GRAPH_GOLDEN_API_KEY=

# Optional extra JSON merged into every request body. Use to disable native "thinking"
# on reasoning models that honor it (those are slow and unlike the production graph
# path — prefer fast non-reasoning models for this work). Example for Ollama:
# GRAPH_GOLDEN_EXTRA_BODY={"think": false}
