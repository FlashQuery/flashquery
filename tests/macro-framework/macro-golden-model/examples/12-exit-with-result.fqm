# Explicit success exit with a structured return value.
#
# Demonstrates the OUT side of the macro's function-call contract: the macro
# does its mechanical work, then calls `exit value` to hand a structured
# Value back to the caller (the LLM, in a real call_macro invocation).
#
# This is the canonical pattern for skill workflows that embed macros — the
# macro does the deterministic batch operation, then exits with the data
# the surrounding LLM workflow needs to continue.
#
# Demonstrates:
#   - Doing the work via fq.* tool calls
#   - Narrating progress via `echo` (writes to the trace/log channel)
#   - Returning a structured value via `exit` (sets the result field)
#   - Channel separation: narration in trace, structured handoff in result
#
# Expected runner behavior: macro completes successfully; the runner prints
# "--- macro result ---" followed by the structured JSON the macro exited
# with. The LLM consuming this in a real workflow would field-access result
# directly (e.g. result.file.fq_id, result.summary).

drafts = fq.search({ query: "tag:#draft" })

# Mechanical work: build a list of {id, title, path} records.
catalog = []
for d in $drafts do
  catalog = append $catalog {
    fq_id: $d.fq_id,
    title: $d.title,
    path: $d.path
  }
done

n = count $catalog
echo "indexed $n drafts"

# Persist the catalog as a markdown doc so the LLM can refer back to it.
saved = fq.write_document({
  mode: "create",
  path: "Research/draft-catalog.md",
  title: "Draft catalog",
  content: "auto-generated by 12-exit-with-result.fqm"
})

# Now exit with a structured handoff. The LLM consuming this in a workflow
# will read result.summary as a narration line AND result.file.* as the
# typed handle for the saved doc. Both in one structured value.
exit {
  summary: "indexed $n drafts and saved a catalog at $saved.path",
  count: $n,
  catalog: $catalog,
  file: $saved
}
