# Conditions and combinators — comparison operators plus boolean &&/||
# with short-circuit evaluation.
#
# Demonstrates:
#   - Comparison operators (REQ-012): == != < > <= >=
#   - Boolean combinators with short-circuit semantics (REQ-013 ac2/ac3):
#     `a && b` returns the falsy `a` WITHOUT evaluating `b`;
#     `a || b` returns the truthy `a` WITHOUT evaluating `b`.
#   - Truthiness rules (REQ-021): empty string is falsy, non-empty truthy;
#     0 is falsy, non-zero numbers truthy.
#
# Note on boolean literals: per §3.3 item 1 of the spec, boolean *literals*
# in macro source were deferred from v0. The golden parses `true`/`false`
# as keywords for forward compatibility, but this example sticks to the
# pre-v1 idiom of using strings ("true"/"false"/"yes"/...) as flag values
# so it reads the same against either parser.

threshold = 5
total = 7
phase = "ready"

# --- Equality and inequality (REQ-012 ac1) -----------------------------

if $total == 7 then
  echo "ok: total matches expected value 7 (== returns true)"
fi

if $phase != "draft" then
  echo "ok: phase \"ready\" is past draft phase (!= returns true)"
fi

# --- Ordering (REQ-012 ac1, numeric) -----------------------------------

if $total > $threshold then
  echo "ok: total $total exceeds threshold $threshold (> returns true)"
fi

if $threshold <= $total then
  echo "ok: threshold $threshold <= total $total"
fi

# --- Combinator: && with short-circuit (REQ-013 ac2) -------------------
# Truthy LHS — RHS IS evaluated. Should print BOTH the search log line
# and the success line.

echo "case A: phase=\"ready\" && fq.search(...) — RHS should run"
if $phase && fq.search({ query: "tag:#draft" }) then
  echo "  -> both operands evaluated; the search ran (look for its log above)"
fi

# Falsy LHS — RHS is NOT evaluated. The search log line MUST NOT appear
# for case B. If you see "[fq] search(...)" between the case-B header
# and the next echo, the short-circuit broke.

empty = ""
echo "case B: empty=\"\" && fq.search(...) — RHS should be skipped"
if $empty && fq.search({ query: "tag:#never" }) then
  echo "  -> unreachable; LHS is falsy"
else
  echo "  -> RHS skipped (look: no [fq] search line between case-B header and here)"
fi

# --- Combinator: || with short-circuit (REQ-013 ac3) -------------------
# Truthy LHS short-circuits ||; RHS is skipped.

if $phase == "ready" || fq.search({ query: "tag:#also-never" }) then
  echo "ok: LHS true; || skipped the search call on the RHS"
fi

# Falsy LHS: RHS IS evaluated. Mixing different conditions.

allow = "false"
if $allow == "true" || $total > 5 then
  echo "ok: permitted via total threshold ($total > 5)"
fi

# --- Truthiness rules (REQ-021) ----------------------------------------

zero = 0
nonzero = 42
empty_list = []
filled_list = ["a"]

if $zero then
  echo "unexpected: 0 should be falsy"
else
  echo "ok: 0 is falsy (REQ-021)"
fi

if $nonzero then
  echo "ok: 42 is truthy (REQ-021)"
fi

if $empty_list then
  echo "unexpected: [] should be falsy"
else
  echo "ok: [] is falsy (REQ-021)"
fi

if $filled_list then
  echo "ok: [\"a\"] is truthy (REQ-021)"
fi

exit {
  threshold: $threshold,
  total: $total,
  phase: $phase,
  conclusion: "comparison + combinators verified; short-circuit confirmed by absence of skipped-RHS log lines"
}
