# `continue` and `break` loop-control statements (Tier 2 / REQ-104).
#
# Extends the v1 loop grammar with the two control statements every
# script language carries:
#
#   - `continue` skips the remainder of the current iteration; control
#     proceeds to the next iteration (or exits if exhausted).
#   - `break` exits the innermost enclosing loop immediately; execution
#     proceeds past `done`. Neither halts the macro itself.
#
# Both are parse-time errors outside a `for` / `while` body.
#
# Demonstrates:
#   - `continue` inside a `for` loop to filter items
#   - `break` inside a `while` loop to stop after N matches
#   - state_notes capture each control event with a `control` marker
#     (visible in the snapshot envelope) for testgen assertions.

# Pretend we have a mixed list of doc records: some are drafts, some
# are published. `fq.search` returns the canned set from the mock.
docs = fq.search({ query: "tag:#draft" })

echo "=== Pass 1: 'continue' to skip drafts with no related_to ==="
matched = []
for d in $docs do
  # Skip records whose related_to list is empty — they're not relevant
  # to this pass. Without `continue`, we'd need to nest the body inside
  # an `if`. With it, the filter sits up front and the body stays flat.
  rel_count = count $d.frontmatter.related_to
  if $rel_count == 0 then
    echo "  skipping $d.fq_id (no related_to)"
    continue
  fi
  matched = append $matched $d.fq_id
  echo "  matched $d.fq_id (related_to has $rel_count entries)"
done

matched_count = count $matched
echo "  -> matched $matched_count docs after filtering"

# === Pass 2: 'break' inside a while loop, stopping after a target ===
echo ""
echo "=== Pass 2: 'break' inside while-loop, stop after 2 hits ==="
i = 0
hits = 0
target = 2
while $i < 10 do
  i = add $i 1
  # Simulate a per-iteration check — say every odd iteration is a "hit".
  is_hit = mod $i 2
  if $is_hit == 1 then
    hits = add $hits 1
    echo "  iter $i: hit (#$hits)"
    if $hits >= $target then
      echo "  reached target — break"
      break
    fi
  else
    echo "  iter $i: miss"
  fi
done

echo "  -> stopped at iter $i with $hits hits (target was $target)"

# === Pass 3: 'break' INSIDE a nested for-loop only breaks the inner ===
# REQ-104 semantics: `break` unwinds the innermost enclosing loop. The
# outer loop keeps going. Demonstrates the scoping rule.
echo ""
echo "=== Pass 3: 'break' only exits the innermost loop ==="
outer_count = 0
for o in 1..3 do
  outer_count = add $outer_count 1
  echo "  outer $o starts"
  for j in 1..5 do
    if $j == 3 then
      echo "    inner: breaking at j=3"
      break
    fi
    echo "    inner j=$j"
  done
  echo "  outer $o continues after inner break"
done
echo "  -> outer ran $outer_count times (inner break did NOT escape outer)"

exit {
  matched_drafts: $matched,
  while_hits: $hits,
  while_final_i: $i,
  outer_count: $outer_count
}
